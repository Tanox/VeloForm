{
  "entities": {
    "Configuration": {
      "title": "Configuration",
      "description": "A bicycle configuration created by a user.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this configuration."
        },
        "bikeType": {
          "type": "string",
          "enum": ["Road", "MTB", "Fold"],
          "description": "The category of the bike."
        },
        "name": {
          "type": "string",
          "description": "The name of the configuration (e.g. S-Works Tarmac SL8)."
        },
        "components": {
          "type": "array",
          "description": "The components included in this configuration."
        },
        "totalCost": {
          "type": "number"
        },
        "estimatedWeight": {
          "type": "number"
        },
        "createdAt": {
          "type": "object",
          "description": "Firestore Timestamp"
        },
        "updatedAt": {
          "type": "object",
          "description": "Firestore Timestamp"
        }
      },
      "required": ["userId", "bikeType", "name", "components", "totalCost", "estimatedWeight", "createdAt", "updatedAt"]
    },
    "ConfigComponent": {
      "title": "ConfigComponent",
      "description": "A single component in a configuration.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "weight": {
          "type": "number"
        }
      },
      "required": ["id", "category", "name", "price", "weight"]
    },
    "DatabaseComponent": {
      "title": "DatabaseComponent",
      "description": "A global bicycle component available for builds.",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "category": { "type": "string" },
        "bikeType": { "type": "string" },
        "price": { "type": "number" },
        "weight": { "type": "number" },
        "specs": { "type": "string" }
      },
      "required": ["brand", "model", "category", "bikeType", "price", "weight", "specs"]
    }
  },
  "firestore": {
    "/components/{componentId}": {
      "schema": {
        "$ref": "#/entities/DatabaseComponent"
      },
      "description": "Global dictionary of all components."
    },
    "/configurations/{configurationId}": {
      "schema": {
        "$ref": "#/entities/Configuration"
      },
      "description": "Stores user generated bike configurations."
    }
  }
}
